<section class="contact-section section">
  <div class="contact-section__intro">
    <p class="contact-section__eyebrow">Neruva Support</p>
    <h1>{{ page.title | default: 'Contact' | escape }}</h1>
    {% if page.content != blank %}
      <div class="contact-section__content rte">
        {{ page.content }}
      </div>
    {% else %}
      <p>Questions about your order, sleep essentials, or returns? Send us a note and we will get back to you soon.</p>
    {% endif %}
  </div>

  <div class="contact-section__card">
    {% form 'contact', class: 'contact-form' %}
      {% if form.posted_successfully? %}
        <p class="contact-form__success" tabindex="-1" autofocus>Thank you for contacting Neruva. We will reply as soon as possible.</p>
      {% endif %}

      {% if form.errors %}
        <div class="contact-form__errors" role="alert">
          <p>Please correct the highlighted fields and try again.</p>
          {{ form.errors | default_errors }}
        </div>
      {% endif %}

      <div class="contact-form__field-grid">
        <div class="contact-form__field">
          <label for="ContactFormName">Name</label>
          <input id="ContactFormName" type="text" name="contact[name]" value="{% if form.name %}{{ form.name | escape }}{% elsif customer %}{{ customer.name | escape }}{% endif %}" autocomplete="name">
        </div>

        <div class="contact-form__field">
          <label for="ContactFormEmail">Email <span aria-hidden="true">*</span></label>
          <input id="ContactFormEmail" type="email" name="contact[email]" value="{% if form.email %}{{ form.email | escape }}{% elsif customer %}{{ customer.email | escape }}{% endif %}" autocomplete="email" autocorrect="off" autocapitalize="off" required>
        </div>
      </div>

      <div class="contact-form__field">
        <label for="ContactFormPhone">Phone</label>
        <input id="ContactFormPhone" type="tel" name="contact[phone]" value="{{ form.phone | escape }}" autocomplete="tel">
      </div>

      <div class="contact-form__field">
        <label for="ContactFormMessage">Message <span aria-hidden="true">*</span></label>
        <textarea id="ContactFormMessage" name="contact[body]" rows="7" required>{{ form.body | escape }}</textarea>
      </div>

      <button type="submit" class="button contact-form__button">Send Message</button>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Contact form",
  "settings": []
}
{% endschema %}
