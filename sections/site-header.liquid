<header class="nav-wrap">
  <a href="{{ routes.root_url }}" class="brand" aria-label="Neruva Home">
    <img src="{{ 'neruva-logo.svg' | asset_url }}" alt="Neruva" class="brand-image" width="220" height="49" loading="eager">
  </a>
  <nav class="nav-left" aria-label="Primary">
    <a href="{{ routes.root_url }}">Home</a>
    <a href="/collections/all">Shop All</a>
    <a href="/pages/help">Help</a>
  </nav>
  <button class="cart-trigger button-unstyled" type="button" data-cart-open aria-haspopup="dialog" aria-label="Open cart">
    <span class="cart-trigger__icon" aria-hidden="true">🛒</span>
    <span>Cart</span>
    <span class="cart-trigger__count" data-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
  </button>
</header>

{% schema %}
{
  "name": "Site header",
  "settings": []
}
{% endschema %}
